{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aisd:schemas:opensky-diode-pipeline:1",
  "title": "OpenSky diode pipeline schema",
  "type": "object",
  "additionalProperties": false,
  "x-provider": {
    "url": "https://opensky-network.org/api/states/all",
    "records_path": "/states",
    "root_unix_ts_path": "/time",
    "output_ts_field": "ts",
    "fields": [
      { "name": "icao24", "record_pointer": "/0" },
      { "name": "lon", "record_pointer": "/5" },
      { "name": "lat", "record_pointer": "/6" },
      { "name": "baro_altitude", "record_pointer": "/7" },
      { "name": "velocity", "record_pointer": "/9" },
      { "name": "true_track", "record_pointer": "/10" },
      { "name": "vertical_rate", "record_pointer": "/11" },
      { "name": "geo_altitude", "record_pointer": "/13" }
    ]
  },
  "x-inputSchemaPointer": "/$defs/opensky_response",
  "properties": {
    "ts": { "type": "string", "format": "date-time", "x-allowUpstream": true },
    "icao24": { "type": "string", "pattern": "^[0-9a-fA-F]{6}$", "x-allowUpstream": true },
    "lat": { "type": ["number", "null"], "minimum": -90, "maximum": 90, "multipleOf": 0.00001, "x-allowUpstream": true },
    "lon": { "type": ["number", "null"], "minimum": -180, "maximum": 180, "multipleOf": 0.00001, "x-allowUpstream": true },
    "velocity": { "type": ["number", "null"], "minimum": 0, "x-allowUpstream": true },
    "true_track": { "type": ["number", "null"], "minimum": 0, "maximum": 360, "x-allowUpstream": true },
    "geo_altitude": { "type": ["number", "null"], "x-allowUpstream": true },
    "baro_altitude": { "type": ["number", "null"], "x-allowUpstream": true },
    "vertical_rate": { "type": ["number", "null"], "x-allowUpstream": true }
  },
  "required": ["ts", "icao24"],
  "$defs": {
    "opensky_state_vector": {
      "type": "array",
      "minItems": 17,
      "items": [
        { "type": "string" },
        {},
        {},
        {},
        {},
        { "type": ["number", "null"] },
        { "type": ["number", "null"] },
        { "type": ["number", "null"] },
        {},
        { "type": ["number", "null"] },
        { "type": ["number", "null"] },
        { "type": ["number", "null"] },
        {},
        { "type": ["number", "null"] },
        {},
        {},
        {}
      ]
    },
    "opensky_response": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "time": { "type": "integer" },
        "states": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/opensky_state_vector" }
        }
      },
      "required": ["time", "states"]
    }
  }
}
